{
  "manifest_version": 3,
  "name": "Viri Bridge",
  "version": "1.2.51",
  "description": "Viri Decentralized Live Bank Transfer Verification Bridge.",
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "permissions": [
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess",
    "cookies",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ruleset_1",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "externally_connectable": {
    "matches": [
      "http://localhost/*",
      "http://127.0.0.1/*",
      "https://*.viri.app/*",
      "https://soft.thinksafe.mv/*",
      "https://viri.thinksafe.mv/*"
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost/*",
        "http://127.0.0.1/*",
        "https://*.viri.app/*",
        "https://soft.thinksafe.mv/*",
        "https://viri.thinksafe.mv/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
