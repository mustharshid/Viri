{
  "manifest_version": 3,
  "name": "Viri Bridge",
  "version": "1.0.7",
  "description": "Viri Decentralized Live Bank Transfer Verification Bridge.",
  "background": {
    "service_worker": "background.js"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "permissions": [
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess",
    "cookies",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "externally_connectable": {
    "matches": [
      "http://localhost/*",
      "http://127.0.0.1/*",
      "https://*.viri.app/*",
      "https://soft.thinksafe.mv/*",
      "https://viri.thinksafe.mv/*"
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost/*",
        "http://127.0.0.1/*",
        "https://*.viri.app/*",
        "https://soft.thinksafe.mv/*",
        "https://viri.thinksafe.mv/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
