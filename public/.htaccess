<IfModule mod_rewrite.c>
    <IfModule mod_negotiation.c>
        Options -MultiViews -Indexes
    </IfModule>

    DirectoryIndex viri/index.html index.php

    RewriteEngine On

    # Handle Authorization Header
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # Redirect Trailing Slashes If Not A Folder...
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} (.+)/$
    RewriteRule ^ %1 [L,R=301]

    # 1. Route API requests to Laravel's Front Controller
    RewriteRule ^api/(.*)$ index.php [L]

    # 2. Transparently route PWA assets to the /viri/ subfolder
    RewriteRule ^assets/(.*)$ viri/assets/$1 [L]
    RewriteRule ^vite\.svg$ viri/vite.svg [L]
    RewriteRule ^favicon\.ico$ viri/favicon.ico [L]

    # 3. For any other request that isn't a file, serve the PWA index.html
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^(.*)$ viri/index.html [L]
</IfModule>
